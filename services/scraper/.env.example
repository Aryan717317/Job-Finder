AJH_ENV=dev
AJH_DATABASE_URL=sqlite:///./data/ajh.db
AJH_DATA_DIR=./data
AJH_PROFILE_DIR=./profiles
AJH_TIMEOUT_MS=45000
AJH_LOCALE=en-IN
AJH_TIMEZONE=Asia/Kolkata
AJH_MAX_PARALLEL_RUNS=2
AJH_MAX_PLATFORM_RETRIES=2
AJH_RETRY_BACKOFF_BASE_SECONDS=1.2
AJH_RETRY_BACKOFF_CAP_SECONDS=12.0

GMAIL_SENDER=
GMAIL_APP_PASSWORD=
GMAIL_RECIPIENT=
EMAIL_MAX_RETRIES=3
EMAIL_RETRY_DELAY_SECONDS=2.0
FLASK_SECRET_KEY=change-me
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
DASHBOARD_PORT=5000
AUTO_CYCLE_ENABLED=false
AUTO_CYCLE_MINUTES=60
AUTO_CYCLE_QUERY=AI/ML Engineer
AJH_CYCLE_LOG_PATH=services/scraper/data/logs/cycle_runner.log
